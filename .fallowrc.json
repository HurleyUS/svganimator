{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/main/index.ts", "src/preload/index.ts", "src/renderer/src/main.tsx"],
  "framework": [
    {
      "name": "bun-tests",
      "enablers": ["@testing-library/react"],
      "entryPoints": ["src/**/*.test.ts", "src/**/*.test.tsx"],
      "entryPointRole": "test",
      "alwaysUsed": ["src/renderer/src/test/**"],
      "toolingDependencies": ["@happy-dom/global-registrator", "@testing-library/react", "happy-dom"]
    }
  ],
  "ignorePatterns": ["./out/**", "./inspiration-docs/**", "out/**", "inspiration-docs/**"],
  "duplicates": {
    "ignore": [
      "./out/**",
      "./inspiration-docs/**",
      "out/**",
      "dist/**",
      "node_modules/**",
      "inspiration-docs/**"
    ]
  },
  "health": {
    "ignore": [
      "./out/**",
      "./inspiration-docs/**",
      "out/**",
      "dist/**",
      "node_modules/**",
      "inspiration-docs/**"
    ]
  },
  "rules": {}
}
